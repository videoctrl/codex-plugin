{
  "videocontrol": {
    "command": "node",
    "args": [
      "__ABS_REPO_ROOT__/packages/mcp-server/dist/index.js",
      "--stdio"
    ],
    "env": {
      "VIDEOCONTROL_MODE": "local",
      "VIDEOCONTROL_PREVIEW_PORT": "48731",
      "PATH": "__LOCAL_PATH__"
    },
    "startup_timeout_sec": 20,
    "tool_timeout_sec": 300
  }
}
