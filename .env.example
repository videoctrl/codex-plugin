# Copy this file to .env only for local development notes or shell tooling.
# Do not commit .env. Codex local plugin setup works without API keys.

VIDEOCONTROL_MODE=local
VIDEOCONTROL_PREVIEW_PORT=48731

# Optional local file locations.
# Leave these unset unless you want to override the defaults.
# Defaults:
#   provider secrets: ~/.videocontrol/secrets/providers.local.json
#   creative preferences: ~/.videocontrol/preferences.json
#   ComfyUI workflows: ~/.videocontrol/comfyui-workflows
VIDEOCONTROL_PROVIDER_SECRETS=
VIDEOCONTROL_PREFERENCES=
VIDEOCONTROL_COMFYUI_WORKFLOWS=

# Optional local ComfyUI endpoint.
COMFYUI_URL=http://127.0.0.1:8188

# Optional provider keys for provider CLIs that support shell keys.
# Browser sign-in or the private provider secrets file is preferred.
AGENT_MEDIA_API_KEY=
POSTIZ_API_URL=
POSTIZ_API_KEY=
